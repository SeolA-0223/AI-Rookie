{
  "name": "ai-rookie",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node backend/src/server.js",
    "test": "node --test --test-isolation=none tests/*.test.js",
    "eval": "node scripts/evaluate.js",
    "smoke": "node scripts/smoke.js",
    "check": "npm run test && npm run eval",
    "handover:update": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/update-handover.ps1",
    "hooks:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-hooks.ps1",
    "hooks:doctor": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/hooks-doctor.ps1"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1"
  }
}
